{% extends "base.html.twig" %}

{% block title %}Création d'un vacataire{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1>Création d'un vacataire</h1>

    {{ form_start(form) }}

    <div class="mb-3">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom) }}
        {{ form_errors(form.nom) }}
    </div>

    <div class="mt-3">
        {{ form_widget(form.submit) }}
    </div>

    {{ form_end(form) }}

</div>
{% endblock %}