{% extends 'base.html.twig' %}

{% block title %}SymVac - Mes vacataires{% endblock %}

{% block body %}
<div class="container mt-4">

    {% for message in app.flashes('success') %}
        <div class="alert alert-dismissible alert-success mt-4">
            {{ message }}
        </div>
    {% endfor %}

    <h1>Mes vacataires</h1>

    <a href="{{ path('vacataire_new') }}" class="btn btn-success mb-3">
        Nouveau vacataire
    </a>

    <table class="table table-hover">
        <thead>
            <tr class="table-secondary">
                <th>Numéro</th>
                <th>Nom</th>
                <th style="width: 220px;">Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for vacataire in vacataires %}
            <tr class="table-dark">
                <td>{{ vacataire.id }}</td>
                <td>{{ vacataire.nom }}</td>

                <td>

                    <a href="{{ path('vacataire_edit', {id: vacataire.id}) }}"
                       class="btn btn-warning btn-sm">
                        Modifier
                    </a>

                    <form method="post"
                          action="{{ path('vacataire_delete', {id: vacataire.id}) }}"
                          class="d-inline">

                        <button
                            class="btn btn-danger btn-sm"
                            onclick="return confirm('Voulez-vous vraiment supprimer ce vacataire ?');">
                            Supprimer
                        </button>

                    </form>

                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(vacataires) }}
    </div>

</div>
{% endblock %}